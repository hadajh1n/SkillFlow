<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_main"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.skillflow.ui.fragment.main.HomeFragment">

        <action
            android:id="@+id/actionHomeToDetails"
            app:destination="@id/detailsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.skillflow.ui.fragment.main.FavoritesFragment">

        <action
            android:id="@+id/actionFavoritesToDetails"
            app:destination="@id/detailsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.skillflow.ui.fragment.main.ProfileFragment"/>

    <fragment
        android:id="@+id/detailsFragment"
        android:name="com.example.skillflow.ui.fragment.main.DetailsFragment">

        <argument
            android:name="courseId"
            app:argType="integer"/>
    </fragment>

</navigation>