<?xml version="1.0" encoding="utf-8"?>
<resources>

    // fragment_login

    <style name="tvTitleEntrance" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/tvTitleEntrance</item>
    </style>

    <style name="tvTitleEmailPassword" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/tvTitleEmailPassword</item>
    </style>

    <style name="edtEmailPassword" parent="Widget.AppCompat.EditText">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/edtEmailPassword</item>
        <item name="android:textColorHint">@color/edtEmailPasswordHint</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="btnEntrance" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:backgroundTint">@color/btnEntranceBg</item>
        <item name="android:textColor">@color/btnEntranceText</item>
    </style>

    <style name="tvTitleRegistration" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvTitleRegistration</item>
    </style>

    <style name="tvRegistration" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvRegistration</item>
    </style>

    <style name="tvForgotPassword" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvForgotPassword</item>
    </style>

    // fragment_home

    <style name="edtSearch" parent="Widget.AppCompat.EditText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/edtSearchText</item>
        <item name="android:textColorHint">@color/edtSearchHint</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="tvSort" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvSort</item>
    </style>

    // item_course_home

    <style name="tvTitleItemCourse" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvTitleItemCourse</item>
    </style>

    <style name="tvItemCourseDescription" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/tvItemCourseDescription</item>
    </style>

    <style name="tvItemCourseCost" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvItemCourseCost</item>
    </style>

    <style name="tvItemCourseDetails" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tvItemCourseDetails</item>
    </style>

