<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="tvTitleEntrance" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/tvTitleEntrance</item>
    </style>

    <style name="tvTitleEmailPassword" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/tvTitleEmailPassword</item>
    </style>

    <style name="edtEmailPassword" parent="Widget.AppCompat.EditText">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:textColor">@color/edtEmailPassword</item>
        <item name="android:textColorHint">@color/edtEmailPasswordHint</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="btnEntrance" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">roboto</item>
        <item name="android:backgroundTint">@color/btnEntranceBg</item>
        <item name="android:textColor">@color/btnEntranceText</item>
    </style>

</resources>